{% extends 'base.html.twig' %}

{% block title %}Admin - Portfolio{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1 class="mb-4">Administration Portfolio 🛠️</h1>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active"
                    data-bs-toggle="tab"
                    data-bs-target="#tab-sections">
                Sections
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link"
                    data-bs-toggle="tab"
                    data-bs-target="#tab-users">
                Utilisateurs
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link"
                    data-bs-toggle="tab"
                    data-bs-target="#tab-settings">
                Paramètres
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 p-3">

        <div class="tab-pane fade show active" id="tab-sections">
           <div class="container mt-4">

                <div class="d-flex justify-content-between mb-3">
                    <button class="btn btn-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#addSectionModal">
                        ➕ Ajouter une Sections
                    </button>
                </div>

                {% include 'admin/section/_table.html.twig' %}
                {% include 'admin/section/_add_modal.html.twig' %}

            </div>
        </div>

        <div class="tab-pane fade" id="tab-users">
            {# {% include 'admin/user/_table.html.twig' %} #}
        </div>

        <div class="tab-pane fade" id="tab-settings">
            {# {% include 'admin/settings/_tab.html.twig' %} #}
        </div>

    </div>
</div>
{% endblock %}
